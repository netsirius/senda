{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Senda",
  "version": "0.1.0",
  "identifier": "app.senda.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Senda",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Hector Santos",
    "category": "DeveloperTool",
    "shortDescription": "Visual local manager for AI CLI custom agents.",
    "longDescription": "Senda is a single-user, local desktop manager for AI CLI custom agents and skills, with multi-provider Git sync and a local automation scheduler."
  }
}
