{
  "name": "senda",
  "version": "0.1.0",
  "private": true,
  "description": "Senda — Visual local manager for AI CLI custom agents and skills",
  "author": "Hector Santos <netsirius@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter senda-desktop tauri dev",
    "build": "pnpm --filter senda-desktop tauri build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.32.1"
}
